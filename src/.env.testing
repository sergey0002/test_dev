APP_NAME="Notification Service"
APP_ENV=testing
APP_KEY=base64:YWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWE=
APP_DEBUG=true
APP_URL=http://localhost:18080

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notification_service
DB_USERNAME=notification
DB_PASSWORD=notification

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_HEARTBEAT=30
RABBITMQ_EXCHANGE=notifications.direct
RABBITMQ_QUEUE_HIGH=notifications.high
RABBITMQ_QUEUE_NORMAL=notifications.normal
RABBITMQ_QUEUE_RETRY_HIGH=notifications.high.retry
RABBITMQ_QUEUE_RETRY_NORMAL=notifications.normal.retry
RABBITMQ_QUEUE_DLQ=notifications.dlq

# Параметры для нагрузочного тестирования:
# - throttle отключен, чтобы rate-limit не мешал генерации трафика;
# - увеличены лимиты ретраев и пачек для стабильной обработки нагрузки.
NOTIFICATION_API_BULK_THROTTLE_ATTEMPTS=10000
NOTIFICATION_API_BULK_THROTTLE_DECAY_MINUTES=1
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_DELAYS=10,30,120
NOTIFICATION_OUTBOX_BATCH_SIZE=100
NOTIFICATION_LOCK_TTL=60
NOTIFICATION_CONSUMER_PREFETCH=10
NOTIFICATION_COMMAND_OUTBOX_LIMIT=100
NOTIFICATION_COMMAND_OUTBOX_SLEEP_SECONDS=2
NOTIFICATION_COMMAND_CONSUMER_LIMIT=0
NOTIFICATION_COMMAND_CONSUMER_WAIT_TIMEOUT_SECONDS=5
NOTIFICATION_COMMAND_LOCK_BLOCK_SECONDS=5
NOTIFICATION_HEALTH_RABBITMQ_TIMEOUT_SECONDS=2
